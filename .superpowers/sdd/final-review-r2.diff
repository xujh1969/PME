+  });
+  const tree = buildMindMapStaticSvg({
+    nodeData: {
+      id: "root",
+      topic: "Root",
+      children: [
+        {
+          id: "child-1",
+          topic: "Child & One",
+          branchColor: "#ff0000",
+          style: { background: "#ffeeee", color: "#550000" },
+          children: [
+            { id: "grandchild", topic: "Grandchild", children: [] },
