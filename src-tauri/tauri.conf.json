{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PME",
  "version": "0.1.1",
  "identifier": "com.pme.editor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5173"
  },
  "app": {
    "windows": [
      {
        "title": "PME",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 640,
        "backgroundColor": "#050505"
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown"],
        "name": "Markdown"
      }
    ]
  }
}
